# env.example — Required environment variables for the Skills-First AI Assistant.
#
# Rename to .env and fill in values:
#   cp env.example .env
#
# NEVER commit .env to version control.
#
# Many of these keys can also be configured by an admin in the Settings UI.
# Env vars take precedence when set.

# ── Infrastructure (required) ─────────────────────────────────────────
SECRET_KEY_BASE=generate-with-mix-phx-gen-secret
PHX_HOST=localhost
PORT=4000
DATABASE_URL=ecto://postgres:postgres@localhost:5432/assistant_prod
CLOAK_ENCRYPTION_KEY=base64-encoded-32-byte-key

# ── LLM Providers ────────────────────────────────────────────────────
# OpenRouter — primary LLM provider (system fallback key)
OPENROUTER_API_KEY=sk-or-...

# OpenAI — optional direct provider path
# OPENAI_API_KEY=sk-...
# OpenAI OAuth (Connect button) uses hardcoded defaults — no config needed.

# ── Google OAuth (required for Google integrations) ──────────────────
# Create OAuth2 credentials at https://console.cloud.google.com/apis/credentials
# Add authorized redirect: https://YOUR_HOST/settings_users/auth/google/callback
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-...

# ── ElevenLabs (TTS — optional) ─────────────────────────────────────
# ELEVENLABS_API_KEY=xi-...
# ELEVENLABS_VOICE_ID=your-voice-id

# ── Telegram Bot (optional) ─────────────────────────────────────────
# Create a bot via @BotFather on Telegram
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# TELEGRAM_WEBHOOK_SECRET=your-webhook-secret

# ── Slack (optional) ────────────────────────────────────────────────
# Create a Slack app at https://api.slack.com/apps
# SLACK_CLIENT_ID=your-client-id
# SLACK_CLIENT_SECRET=your-client-secret
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_SIGNING_SECRET=your-signing-secret

# ── Discord (optional) ────────────────────────────────────────────
# Create a Discord app at https://discord.com/developers/applications
# DISCORD_BOT_TOKEN=your-bot-token
# DISCORD_PUBLIC_KEY=hex-encoded-ed25519-public-key
# DISCORD_APPLICATION_ID=your-application-id

# ── Google Chat (optional) ──────────────────────────────────────────
# GOOGLE_CHAT_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/...

# ── Google write concurrency rollout flags (optional) ──────────────
# Enable incrementally in staging, then production.
# GOOGLE_WRITE_CONFLICT_PROTECTION=false
# GOOGLE_WRITE_LEASE_ENFORCEMENT=false
# GOOGLE_WRITE_AUDIT_HISTORY=false

# ── HubSpot (optional) ─────────────────────────────────────────────
# HUBSPOT_API_KEY=pat-...
